# Campsite Empire local AI configuration
# Copy this file to .env and adjust values for your local provider.

# Leave blank or remove this value to use template fallbacks only.
CAMPSITE_AI_PROVIDER=ollama

# Ollama default endpoint:
CAMPSITE_AI_URL=http://localhost:11434/api/generate

# Example Ollama model. Use any local model you have pulled.
CAMPSITE_AI_MODEL=llama3.1

# llama.cpp OpenAI-compatible server example:
# CAMPSITE_AI_PROVIDER=llamacpp
# CAMPSITE_AI_URL=http://localhost:8080/v1/chat/completions
# CAMPSITE_AI_MODEL=local-model
#
# LM Studio OpenAI-compatible server example:
# CAMPSITE_AI_PROVIDER=lmstudio
# CAMPSITE_AI_URL=http://localhost:1234/v1/chat/completions
# CAMPSITE_AI_MODEL=local-model
